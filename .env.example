# ============================================================
# KitchenPrime — environment variables
# Copy this file to `.env` and fill in real values.
# ============================================================

# Database (PostgreSQL) — required
# Local dev (Docker):  postgresql://kitchenprime:kitchenprime@localhost:5432/kitchenprime
# Vercel (Neon):       postgresql://user:pass@ep-xxx.eu-central-1.aws.neon.tech/kitchenprime?sslmode=require
DATABASE_URL="postgresql://kitchenprime:kitchenprime@localhost:5432/kitchenprime"

# Docker compose helpers (used by docker-compose.yml)
POSTGRES_DB=kitchenprime
POSTGRES_USER=kitchenprime
POSTGRES_PASSWORD=kitchenprime

# NextAuth — required
NEXTAUTH_SECRET=generate-with-openssl-rand-base64-32
NEXTAUTH_URL=http://localhost:3000

# Public site URL (used by Mollie redirect, sitemap, OG)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Admin user (created/updated by `npm run db:seed`)
ADMIN_EMAIL=admin@kitchenprime.com
ADMIN_PASSWORD=ChangeMe!Now2026

# WhatsApp click-to-chat (the float button + product CTAs use this)
NEXT_PUBLIC_WA_NUMBER=33780967339

# Mollie (card payments)
MOLLIE_API_KEY=test_xxxxxxxxxxxxxxxxxxxx

# Wise (manual reconciliation for now)
WISE_API_KEY=

# WhatsApp Cloud API (server-side notifications, optional)
WHATSAPP_TOKEN=
WHATSAPP_PHONE_ID=

# Outbound email (Nodemailer SMTP — SendGrid, Mailgun, Mailtrap, etc.)
SMTP_HOST=smtp.sendgrid.net
SMTP_PORT=587
SMTP_USER=apikey
SMTP_PASS=
SMTP_FROM="KitchenPrime <noreply@kitchenprime.com>"
